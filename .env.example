# ─── Aegix Share — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values before running in production.
# NEVER commit the real .env file to source control.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your actual values
#   python manage.py runserver   # (development)
#   gunicorn backend.wsgi        # (production)

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
# Examples: localhost,127.0.0.1,192.168.1.100,yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
